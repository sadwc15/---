.container {
  padding: 50rpx;
  background: #1a1a1a;
  min-height: 100vh;
  color: white;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.balance {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 60rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.item {
  width: 45%;
  background: #333;
  padding: 40rpx 0;
  text-align: center;
  margin-bottom: 30rpx;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: 2rpx solid transparent;
}

.item.active {
  border-color: #d4af37;
  background: #2a2a2a;
  color: #d4af37;
}

.btn-pay {
  background: #d4af37;
  color: #000;
  margin-top: 60rpx;
  font-weight: bold;
}