<view class="container">
  <view class="grid">
    <view class="card" wx:for="{{list}}" wx:key="index" bindtap="goDetail" data-item="{{item}}">
      <!-- 图片区域 -->
      <view class="img-box">
        <image class="img" src="{{item.detail.image || item.detail.avatar}}" mode="aspectFill"></image>
        <view class="tag {{item.type=='PRODUCT'?'tag-p':'tag-c'}}">
          {{item.type === 'PRODUCT' ? '好物' : '课程'}}
        </view>
      </view>
      
      <!-- 信息区域 -->
      <view class="info">
        <view class="name">{{item.detail.name || item.detail.title}}</view>
        <view class="price-row">
          <text class="price">¥{{item.detail.price}}</text>
          <text class="fav-icon">❤️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{list.length === 0}}" class="empty-box">
    <image src="/assets/images/profile.png" class="empty-img" style="opacity:0.3"></image>
    <view>暂无收藏内容</view>
  </view>
</view>