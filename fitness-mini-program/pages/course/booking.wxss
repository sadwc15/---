.container {
  padding: 30rpx;
  padding-bottom: 250rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.header-card {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.sub {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}

.section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.sec-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #1AAD19;
  padding-left: 16rpx;
}

/* 日期横向滚动 */
.date-scroll {
  display: flex;
  white-space: nowrap;
  height: 120rpx;
  align-items: center;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background: #f8f8f8;
  color: #666;
  flex-shrink: 0;
}

.date-item.active {
  background: #1AAD19;
  color: white;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(26, 173, 25, 0.3);
}

.day-label {
  font-size: 22rpx;
  margin-bottom: 6rpx;
}

.day-num {
  font-size: 34rpx;
}

/* 时间网格 */
.time-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.time-item {
  width: 140rpx;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  color: #666;
  font-size: 28rpx;
}

.time-item.active {
  background: #e8f5e9;
  color: #1AAD19;
  border-color: #1AAD19;
  font-weight: bold;
}

/* 底部栏 */
.footer-pay {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

/* 优惠券条 */
.coupon-bar {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.c-right {
  display: flex;
  align-items: center;
}

.red {
  color: #ff4d4f;
  font-weight: bold;
  margin-right: 10rpx;
}

.gray {
  color: #999;
  margin-right: 10rpx;
}

.arrow {
  color: #ccc;
}

/* 支付行 */
.pay-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx 40rpx;
}

.price-box {
  display: flex;
  align-items: baseline;
}

.symbol {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: bold;
}

.amount {
  color: #ff4d4f;
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.old {
  color: #ccc;
  text-decoration: line-through;
  font-size: 24rpx;
}

.btn-confirm {
  background: #1AAD19;
  color: white;
  border-radius: 40rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-weight: bold;
  margin: 0;
}

/* 弹窗样式 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.coupon-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #f5f7fa;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: all 0.3s;
  padding-bottom: 40rpx;
  min-height: 600rpx;
}

.coupon-modal.show {
  transform: translateY(0);
}

.modal-title {
  text-align: center;
  padding: 30rpx;
  font-weight: bold;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
}

.c-list {
  max-height: 500rpx;
  padding: 30rpx;
}

.c-item {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.c-amt {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-right: 20rpx;
}

.c-name {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.circle {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
}

.btn-close {
  margin: 30rpx;
  background: white;
  color: #666;
}