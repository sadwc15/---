.container {
  background: #f7f8fa;
  min-height: 100vh;
}

/* 搜索框样式 */
.search-box {
  background: white;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-input {
  margin-left: 20rpx;
  font-size: 28rpx;
  flex: 1;
  height: 60rpx;
}

/* 列表容器 */
.list-container {
  padding: 20rpx;
}

/* 卡片样式 */
.coach-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-left {
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #eee;
  border: 1rpx solid #f0f0f0;
}

.card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.row-1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.coach-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.course-price {
  color: #ff5500;
  font-weight: bold;
  font-size: 30rpx;
}

.coach-bio {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 20rpx;
  color: #1AAD19;
  background: #f0f9eb;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.divider {
  height: 1rpx;
  background: #f5f5f5;
  margin-bottom: 20rpx;
}

.row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.avail-text {
  font-size: 22rpx;
  color: #999;
}

.btn-book {
  background: #1AAD19;
  color: white;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin: 0;
  line-height: 2;
}

.empty {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
}