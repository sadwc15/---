.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 加载中、空状态、错误提示 */
.loading, .empty, .error {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  font-size: 32rpx;
  color: #999;
}

.error {
  color: #ff6b6b;
}

/* 课程卡片 */
.course-card {
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  margin-bottom: 30rpx;
}

/* 卡片头部 */
.card-header {
  position: relative;
  height: 300rpx;
}

.course-image {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
}

.status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
}

.status-0 {
  background-color: #52c41a;
}

.status-1 {
  background-color: #1890ff;
}

.status-2 {
  background-color: #999;
}

/* 卡片主体 */
.card-body {
  padding: 30rpx;
}

.course-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.label {
  color: #999;
  width: 140rpx;
}

.value {
  color: #333;
  flex: 1;
}

/* 倒计时 */
.countdown-section {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
  text-align: center;
}

.countdown-label {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.countdown-time {
  font-size: 80rpx;
  font-weight: bold;
  color: #1890ff;
  font-family: monospace;
}

/* 卡片底部 */
.card-footer {
  padding: 0 30rpx 30rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: opacity 0.3s;
}

.btn:active {
  opacity: 0.8;
}

.btn-start {
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
}

.btn-finish {
  background: linear-gradient(135deg, #ff6b6b, #ff4d4f);
  color: #fff;
}

.finished-tag {
  text-align: center;
  font-size: 32rpx;
  color: #999;
  padding: 20rpx 0;
}

.finished-tag text {
  background-color: #f5f5f5;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
}

/* 按钮禁用状态 */
.btn[disabled] {
  opacity: 0.5;
}