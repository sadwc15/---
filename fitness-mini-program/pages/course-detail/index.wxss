.container {
  padding-bottom: 120rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.banner {
  width: 100%;
  height: 500rpx;
}

.info-card {
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  margin-top: -40rpx;
  padding: 40rpx;
  position: relative;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.label {
  color: #999;
  width: 100rpx;
}

.val {
  color: #333;
  font-weight: 500;
}

.desc {
  margin-top: 40rpx;
  border-top: 1rpx solid #eee;
  padding-top: 30rpx;
}

.desc-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 10rpx rgba(0, 0, 0, 0.05);
  justify-content: space-between;
}

.price-box {
  display: flex;
  align-items: center;
}

.unit {
  font-size: 24rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.num {
  font-size: 48rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.red {
  color: #ff4d4f;
}

.tag {
  font-size: 20rpx;
  background: #ff4d4f;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.discount-info {
  display: flex;
  flex-direction: column;
  font-size: 20rpx;
}

.old {
  text-decoration: line-through;
  color: #ccc;
}

.save {
  color: #ff4d4f;
}

.btn-book {
  margin: 0;
  background: #1AAD19;
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  padding: 0 60rpx;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
}