/* 全局容器 */
.container {
  min-height: 100vh;
  background-color: #fff;
  padding: 40rpx;
  box-sizing: border-box;
}

/* 顶部 Header */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%; /* 圆形头像 */
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 2rpx;
}

.version {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 内容区域 */
.content {
  padding-top: 20rpx;
}

.section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #1AAD19; /* 绿色竖线装饰 */
  padding-left: 20rpx;
}

.section-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 联系方式行 */
.row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  align-items: flex-start;
}

.label {
  color: #888;
  width: 160rpx;
  flex-shrink: 0;
}

.val {
  color: #333;
  flex: 1;
}

.phone {
  color: #1AAD19;
  text-decoration: underline;
}

/* 底部区域 */
.footer-area {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-profile {
  background: #f0f9eb;
  color: #1AAD19;
  font-size: 28rpx;
  border: 1rpx solid #1AAD19;
  border-radius: 40rpx;
  padding: 12rpx 50rpx;
  margin-bottom: 30rpx;
}

.copyright {
  font-size: 22rpx;
  color: #ccc;
}