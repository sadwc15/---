.hero-img {
  width: 100%;
  height: 500rpx;
  background: #eee;
}

.info-box {
  padding: 30rpx;
  background: white;
  border-radius: 20rpx 20rpx 0 0;
  margin-top: -20rpx;
  position: relative;
}

.price {
  color: #ff5500;
  font-size: 44rpx;
  font-weight: bold;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

.stock {
  color: #999;
  font-size: 24rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 30rpx 0;
}

.desc-title {
  font-weight: bold;
  margin-bottom: 10rpx;
}

.desc {
  color: #666;
  line-height: 1.6;
}

.footer {
  position: fixed;
  bottom: 0;
  width: 100%;
  background: white;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-buy {
  background: #ff5500;
  color: white;
  border-radius: 50rpx;
}