.container {
  padding: 20rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-weight: bold;
  font-size: 32rpx;
}

.status {
  font-size: 26rpx;
  font-weight: bold;
}

.status.cancelled {
  color: #999;
}

.status.finished {
  color: #1AAD19;
}

.status.upcoming {
  color: #ff9900;
}

.body {
  margin-bottom: 24rpx;
}

.row {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.footer {
  display: flex;
  justify-content: flex-end;
}

.action-box {
  display: flex;
  gap: 20rpx;
}

.tip {
  font-size: 24rpx;
  color: #ccc;
}

.btn {
  font-size: 24rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  margin: 0;
}

.btn.grey {
  background: #f5f5f5;
  color: #666;
}

.btn.green {
  background: #1AAD19;
  color: white;
}

.btn.outline {
  background: white;
  border: 1rpx solid #1AAD19;
  color: #1AAD19;
}


.btn.blue {
  background: #1296db;
  color: white;
  margin-right: 10rpx;
}

/* 调整一下按钮容器 */
.action-box {
  display: flex;
  align-items: center;
}