.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 加载中状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  font-size: 32rpx;
  color: #999;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

/* 列表容器 */
.session-list {
  height: calc(100vh - 88rpx - 40rpx); /* 减去导航栏高度和内边距 */
}

/* 卡片样式 */
.card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.card:active {
  transform: scale(0.98);
}

/* 左侧头像 */
.card-left {
  margin-right: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  border: 2rpx solid #e0e0e0;
}

/* 中间信息区 */
.card-center {
  flex: 1;
}

.member-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.course-name {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.booking-time {
  font-size: 24rpx;
  color: #999;
}

/* 右侧按钮区 */
.card-right {
  margin-left: 20rpx;
}

.btn-enter {
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #ffffff;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 40rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.3);
  border: none;
  transition: opacity 0.3s;
}

.btn-enter::after {
  border: none;
}

.btn-hover {
  opacity: 0.8;
}

/* 适配iPhone底部安全区 */
.card:last-child {
  margin-bottom: env(safe-area-inset-bottom);
}

/* 教练端两行布局 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 30rpx;
}

.menu-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  color: #333;
}

.menu-box .icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.menu-box .txt {
  font-size: 26rpx;
  color: #666;
}

/* 颜色变体 */
.menu-box.cyan { background: #e6f7ff; }
.menu-box.gold { background: #fff7e6; }
.menu-box.blue { background: #e6f0ff; }
.menu-box.green { background: #e6ffe6; }
.menu-box.orange { background: #fff0e6; }
.menu-box.purple { background: #f3e6ff; }