.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 加载中状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  font-size: 32rpx;
  color: #999;
}

/* 错误提示 */
.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
  font-size: 32rpx;
  color: #ff4d4f;
}

.retry-btn {
  margin-top: 30rpx;
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 40rpx;
}

/* 详情卡片 */
.detail-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 学员信息区域 */
.member-section {
  display: flex;
  align-items: center;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f0f0f0;
  border: 2rpx solid #e0e0e0;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.member-label {
  font-size: 24rpx;
  color: #999;
}

/* 课程信息区域 */
.course-section {
  margin-bottom: 40rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #999;
}

.value {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.status-1 {
  background-color: #1890ff;  /* 上课中蓝色 */
}

.status-2 {
  background-color: #52c41a;  /* 已完成绿色 */
}

/* 操作区域 */
.action-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0f0f0;
  text-align: center;
}

/* 下课按钮 */
.btn-finish {
  background: linear-gradient(135deg, #ff6b6b, #ff4d4f);
  color: #ffffff;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  width: 60%;
  margin: 0 auto;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.3);
  border: none;
}

.btn-finish::after {
  border: none;
}

.btn-finish[disabled] {
  opacity: 0.6;
}

/* 已完成标签 */
.finished-tag {
  text-align: center;
  font-size: 32rpx;
  color: #52c41a;
  padding: 20rpx 0;
}

.finished-tag text {
  background-color: #f6ffed;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  border: 2rpx solid #b7eb8f;
}

/* 待开始提示 */
.pending-tip {
  text-align: center;
  font-size: 32rpx;
  color: #faad14;
  padding: 20rpx 0;
}

.pending-tip text {
  background-color: #fff7e6;
  padding: 16rpx 60rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ffd591;
}