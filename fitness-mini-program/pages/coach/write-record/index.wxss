.container {
  padding: 40rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #333;
}

.form-group {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #666;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 10rpx 30rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.tag.active {
  background: #1AAD19;
  color: white;
}

.area {
  width: 100%;
  height: 300rpx;
  font-size: 28rpx;
  color: #333;
}

.btn-submit {
  background: #1AAD19;
  color: white;
  font-weight: bold;
  border-radius: 50rpx;
  margin-top: 60rpx;
}