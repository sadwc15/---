<view class="container">
  <view class="header-title">我的预约记录</view>

  <view class="list">
    <view class="card" wx:for="{{list}}" wx:key="id">
      
      <!-- 头部：会员名 + 时间 -->
      <view class="card-header">
        <view class="member-name">学员：{{item.member ? item.member.name : '未知学员'}}</view>
        <view class="time">{{item.timeStr}}</view>
      </view>

      <!-- 中部：课程信息 -->
      <view class="card-body">
        <view class="row">课程：{{item.course.title}}</view>
        <view class="row">状态：
          <text class="status {{item.status==2?'red':'green'}}">
            {{item.status == 2 ? '已取消' : (item.status == 1 ? '已完成' : '待上课')}}
          </text>
        </view>
      </view>

      <!-- 底部：操作按钮 -->
      <!-- 只有未取消的订单(status!=2)才允许写报告 -->
      <view class="card-footer" wx:if="{{item.status != 2}}">
         <button class="btn-write" bindtap="goWrite" data-id="{{item.id}}">✍️ 写训练报告</button>
      </view>

    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{list.length === 0}}" class="empty">暂时没有预约记录</view>
</view>