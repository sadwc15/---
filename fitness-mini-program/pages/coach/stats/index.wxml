<view class="coach-card">
  <view class="coach-info">
    <image class="c-avatar" src="{{userInfo.avatar || 'https://images.unsplash.com/photo-1568602471122-7832951cc4c5?w=200'}}" mode="aspectFill"></image>
    <view class="c-text">
      <view class="c-name">{{userInfo.name}} <text class="c-tag">教练</text></view>
      <view class="c-sub">累计上课: {{totalClasses || 0}} 节</view>
    </view>
  </view>
</view>