.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.coupon-item {
  display: flex;
  background: #fff;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.left {
  width: 200rpx;
  background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 99%);
  color: white;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.amount {
  font-size: 32rpx;
}

.amount text {
  font-size: 60rpx;
  font-weight: bold;
}

.cond {
  font-size: 22rpx;
  margin-top: 10rpx;
}

.right {
  flex: 1;
  padding: 30rpx;
  position: relative;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.date {
  font-size: 24rpx;
  color: #999;
}

.btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  background: #fff;
  border: 1rpx solid #ff9a9e;
  color: #ff9a9e;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  margin: 0;
}

.grey .left {
  background: #ccc;
}

.grey .btn {
  border-color: #ccc;
  color: #ccc;
}