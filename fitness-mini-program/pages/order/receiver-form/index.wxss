/* 页面整体容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx 0;
}

/* 页面标题 */
.page-title {
  padding: 30rpx 30rpx 10rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  margin: 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

/* 标签 */
.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 输入框容器 */
.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
}

/* 输入框 */
.input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0;
  background: transparent;
  border: none;
}

/* 数字输入框 */
.input-number {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0;
  background: transparent;
  border: none;
}

/* 占位符颜色 */
.input::placeholder,
.input-number::placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 提交按钮 */
.submit-btn {
  margin: 60rpx 30rpx 40rpx;
  width: calc(100% - 60rpx);
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
}

/* 提示文字 */
.tip {
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}