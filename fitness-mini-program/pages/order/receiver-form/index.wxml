<view class="container">
  <!-- 页面标题 -->
  <view class="page-title">填写收货信息</view>
  
  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 收货人姓名 -->
    <view class="form-item">
      <text class="label">收货人姓名</text>
      <view class="input-wrapper">
        <input class="input" type="text" bindinput="onNameInput" value="{{name}}" placeholder="请输入姓名" />
      </view>
    </view>
    
    <!-- 手机号码 -->
    <view class="form-item">
      <text class="label">手机号码</text>
      <view class="input-wrapper">
        <input class="input-number" type="number" bindinput="onPhoneInput" value="{{phone}}" placeholder="请输入手机号" maxlength="11" />
      </view>
    </view>
    
    <!-- 收货地址 -->
    <view class="form-item">
      <text class="label">收货地址</text>
      <view class="input-wrapper">
        <input class="input" type="text" bindinput="onAddressInput" value="{{address}}" placeholder="请输入详细地址" />
      </view>
    </view>
  </view>
  
  <!-- 提示文字 -->
  <view class="tip">* 请确保信息准确，以便商品顺利送达</view>
  
  <!-- 提交按钮 -->
  <button class="submit-btn" bindtap="submitReceiver">确认并支付</button>
</view>