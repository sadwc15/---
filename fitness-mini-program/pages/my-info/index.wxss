/* 头像区域 - 整体居中 */
.avatar-section {
  padding: 40rpx 0;
  background-color: #fff;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 隐藏原有的标签，因为截图中没有显示“头像”文字 */
.avatar-label {
  display: none;
}

/* 头像容器 - 居中 */
.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

/* 头像图片 - 圆形，大小适中 */
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background-color: #f8f8f8;
}

/* 点击更换文字 - 放在头像下方 */
.avatar-edit {
  font-size: 26rpx;
  color: #666;
  margin-top: 16rpx;
  padding: 8rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

/* 表单区域样式微调 */
.form-item {
  margin: 30rpx 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border: none;
  padding: 0;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.picker {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0;
}

.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.radio radio {
  margin-right: 8rpx;
  transform: scale(0.8);
}

/* 保存按钮样式 */
.save-btn {
  margin: 60rpx 30rpx 40rpx;
  width: calc(100% - 60rpx);
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.save-btn::after {
  border: none;
}