.container {
  background: white;
  min-height: 100vh;
}

.header {
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.date {
  font-size: 26rpx;
  color: #999;
}

.hero-img {
  width: 100%;
  display: block;
}

.content {
  padding: 40rpx 30rpx;
  font-size: 32rpx;
  color: #444;
  line-height: 1.8;
  text-align: justify;
}