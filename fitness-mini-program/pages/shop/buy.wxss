/* 页面整体 */
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 120rpx;
}

/* 商品卡片 */
.product-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 30rpx;
  background-color: #f5f5f5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 10rpx 0;
}

.product-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.product-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #f56c6c;
}

/* 优惠券卡片 */
.coupon-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
  border-left: 8rpx solid #ff9800;
}

.coupon-left {
  display: flex;
  align-items: center;
}

.coupon-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.coupon-text {
  font-size: 28rpx;
  color: #666;
}

.coupon-amount {
  font-size: 32rpx;
  font-weight: 500;
  color: #ff9800;
}

/* 价格卡片 */
.price-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-row.total {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #eee;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.price-value.discount {
  color: #ff9800;
}

.final-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #f56c6c;
}

/* 收货信息卡片 */
.receiver-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.03);
}

.receiver-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.receiver-title {
  display: flex;
  align-items: center;
}

.receiver-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.receiver-title text:last-child {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.receiver-action {
  display: flex;
  align-items: center;
}

.action-text {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.action-text.fill {
  color: #07c160;
  font-weight: 500;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
  line-height: 1;
}

.receiver-content {
  margin-left: 48rpx;
}

.receiver-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.receiver-address {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.receiver-empty {
  margin-left: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.total-section {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.total-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #f56c6c;
}

.pay-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #07c160 0%, #059b4c 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin: 0;
  padding: 0;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.pay-btn::after {
  border: none;
}

.pay-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}