.container {
  background: #1a1a1a;
  min-height: 100vh;
  padding-bottom: 40rpx;
  color: #fff;
}

.banner {
  background: #333;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #d4af37;
  margin-bottom: 10rpx;
}

.banner-sub {
  font-size: 26rpx;
  color: #888;
}

.goods-list {
  padding: 0 20rpx;
}

.goods-item {
  display: flex;
  background: #2a2a2a;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  padding: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
}

.goods-img {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
  background: #000;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.desc {
  font-size: 24rpx;
  color: #888;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 10rpx;
}

.row-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.price {
  color: #d4af37;
  font-size: 36rpx;
  font-weight: bold;
}

.fav-btn {
  font-size: 24rpx;
  color: #aaa;
  border: 1rpx solid #444;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.empty {
  text-align: center;
  color: #666;
  margin-top: 100rpx;
}